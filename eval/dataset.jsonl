{"id": "vig-01", "category": "vig_removal", "description": "Symmetric -110/-110 spread: each side should be exactly 50%", "inputs": {"prices": [-110, -110]}, "expected": {"fair_probs": [0.5, 0.5], "tolerance": 0.001}}
{"id": "vig-02", "category": "vig_removal", "description": "NFL moneyline -170/+155: favorite gets ~61.6%", "inputs": {"prices": [-170, 155]}, "expected": {"fair_probs": [0.6162, 0.3838], "tolerance": 0.002}}
{"id": "vig-03", "category": "vig_removal", "description": "Heavy favorite -200/+175", "inputs": {"prices": [-200, 175]}, "expected": {"fair_probs": [0.6471, 0.3529], "tolerance": 0.002}}
{"id": "vig-04", "category": "vig_removal", "description": "Totals market O/U with -115/-105 (asymmetric vig)", "inputs": {"prices": [-115, -105]}, "expected": {"fair_probs": [0.5108, 0.4892], "tolerance": 0.002}}
{"id": "vig-05", "category": "vig_removal", "description": "Ratio preservation: no-vig must preserve relative probability ratio", "inputs": {"prices": [-130, 110]}, "expected": {"ratio_preserved": true, "tolerance": 1e-9}}
{"id": "ev-01", "category": "ev_calculation", "description": "Positive EV: fair 53.0% at -108 (line has genuine value)", "inputs": {"blended_prob": 0.53, "american_price": -108}, "expected": {"ev": 0.0207, "tolerance": 0.002}}
{"id": "ev-02", "category": "ev_calculation", "description": "Negative EV: fair 50.0% at -110 (no-vig even-money costs a half-point of juice)", "inputs": {"blended_prob": 0.50, "american_price": -110}, "expected": {"ev": -0.0455, "tolerance": 0.002}}
{"id": "ev-03", "category": "ev_calculation", "description": "Dog with edge: fair 60.0% at +140 (strong positive EV)", "inputs": {"blended_prob": 0.60, "american_price": 140}, "expected": {"ev": 0.44, "tolerance": 0.002}}
{"id": "ev-04", "category": "ev_calculation", "description": "Breakeven check: fair prob that equals implied prob should have EV near zero", "inputs": {"blended_prob": 0.5238, "american_price": -110}, "expected": {"ev_near_zero": true, "tolerance": 0.01}}
{"id": "clv-01", "category": "clv_calculation", "description": "Positive CLV: bet at fair 52%, closes at fair 55% (found value before market moved)", "inputs": {"blended_probability": 0.52, "closing_probability": 0.55}, "expected": {"clv": 0.03, "tolerance": 0.001}}
{"id": "clv-02", "category": "clv_calculation", "description": "Negative CLV: bet at fair 55%, closes at fair 50% (market disagreed)", "inputs": {"blended_probability": 0.55, "closing_probability": 0.50}, "expected": {"clv": -0.05, "tolerance": 0.001}}
{"id": "clv-03", "category": "clv_calculation", "description": "Zero CLV: bet and close at same fair prob", "inputs": {"blended_probability": 0.536, "closing_probability": 0.536}, "expected": {"clv": 0.0, "tolerance": 0.0001}}
{"id": "edge-01", "category": "edge_filter", "description": "Above threshold: fair 54.5% vs implied 51.9% at -108 gives 2.6% edge", "inputs": {"blended_prob": 0.545, "american_price": -108, "min_edge_pct": 0.02}, "expected": {"passes_filter": true, "edge_pct": 0.026, "tolerance": 0.002}}
{"id": "edge-02", "category": "edge_filter", "description": "Below threshold: fair 51.5% vs implied 52.4% at -110 is negative edge, filtered", "inputs": {"blended_prob": 0.515, "american_price": -110, "min_edge_pct": 0.02}, "expected": {"passes_filter": false, "edge_pct": -0.009, "tolerance": 0.002}}
{"id": "edge-03", "category": "edge_filter", "description": "Above threshold: edge ~2.1% at -110 (0.5440 blended - 0.5238 implied) passes filter", "inputs": {"blended_prob": 0.5440, "american_price": -110, "min_edge_pct": 0.02}, "expected": {"passes_filter": true, "tolerance": 0.002}}
{"id": "struct-01", "category": "structural", "description": "Valid pick candidate: all required fields, positive edge, valid confidence enum", "inputs": {"pick": {"pick_id": "eval-pick-1", "game_id": "game-eval-1", "home_team": "Kansas City Chiefs", "away_team": "Las Vegas Raiders", "commence_time": "2026-09-07T20:00:00", "market": "spreads", "selection": "Kansas City Chiefs -3.5", "best_book": "draftkings", "best_price": -108, "sharp_probability": 0.545, "blended_probability": 0.545, "implied_probability": 0.519, "edge_pct": 0.026, "ev_pct": 0.021, "confidence": "medium", "rationale": "Sharp line held at -3.5 while public backed Raiders, suggesting sharp money on Chiefs."}}, "expected": {"valid": true}}
{"id": "struct-02", "category": "structural", "description": "Invalid confidence value should fail schema validation", "inputs": {"pick": {"confidence": "extreme"}}, "expected": {"valid": false, "reason": "confidence not in [high, medium, low]"}}
{"id": "struct-03", "category": "structural", "description": "Edge and implied prob must be consistent: edge_pct = blended - implied", "inputs": {"blended_probability": 0.545, "implied_probability": 0.519, "edge_pct": 0.026}, "expected": {"consistent": true, "tolerance": 0.001}}
